#!/usr/bin/env bash
set -euo pipefail

# Codex CLI (MiMo) — install if missing, then launch with MiMo API
# 直接运行 codex 走用户登录的 ChatGPT（全局 0.80.0）
# 通过此脚本/xmcodex 运行走 MiMo API（nvm codex-mimo 0.78.0，完全隔离）

CODEX_NODE_VERSION="22"
CODEX_NVM_ALIAS="codex-mimo"
CODEX_PKG="@openai/codex"
CODEX_VERSION="0.78.0"
CODEX_REGISTRY="https://registry.npmmirror.com"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"
MIMO_HOME="$SCRIPT_DIR/home"

info()  { printf "\033[1;34m[INFO]\033[0m  %s\n" "$*"; }
ok()    { printf "\033[1;32m[OK]\033[0m    %s\n" "$*"; }

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$ENV_FILE"
    set +a
  fi
}

ensure_nvm() {
  if command -v nvm &>/dev/null; then
    return
  fi
  local nvm_dir="${NVM_DIR:-$HOME/.nvm}"
  if [[ -s "$nvm_dir/nvm.sh" ]]; then
    # shellcheck source=/dev/null
    source "$nvm_dir/nvm.sh"
    return
  fi
  info "Installing nvm..."
  curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
  export NVM_DIR="$nvm_dir"
  # shellcheck source=/dev/null
  [[ -s "$nvm_dir/nvm.sh" ]] && source "$nvm_dir/nvm.sh"
}

is_installed() {
  nvm exec "$CODEX_NVM_ALIAS" command -v codex &>/dev/null 2>&1
}

do_install() {
  info "First run — installing Codex CLI $CODEX_VERSION (MiMo)..."

  nvm install "$CODEX_NODE_VERSION"
  nvm alias "$CODEX_NVM_ALIAS" "$CODEX_NODE_VERSION" 2>/dev/null || true
  ok "Node.js $(nvm exec "$CODEX_NVM_ALIAS" node --version)"

  nvm exec "$CODEX_NVM_ALIAS" npm install -g "$CODEX_PKG@$CODEX_VERSION" --registry="$CODEX_REGISTRY"
  ok "codex $(nvm exec "$CODEX_NVM_ALIAS" codex --version 2>/dev/null || echo 'installed')"
  echo ""
}

main() {
  load_env
  ensure_nvm

  if ! is_installed; then
    do_install
  fi

  # CODEX_HOME points to plugin's own config — user's ~/.codex is untouched
  CODEX_HOME="$MIMO_HOME" nvm exec "$CODEX_NVM_ALIAS" codex "$@"
}

main "$@"
