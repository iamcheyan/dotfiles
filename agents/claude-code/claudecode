#!/usr/bin/env bash
set -euo pipefail

# Claude Code — setup config symlinks if needed, then launch

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"
CLAUDE_HOME="$HOME/.claude"

info()  { printf "\033[1;34m[INFO]\033[0m  %s\n" "$*"; }
ok()    { printf "\033[1;32m[OK]\033[0m    %s\n" "$*"; }

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$ENV_FILE"
    set +a
  fi
}

is_installed() {
  command -v claude &>/dev/null
}

do_install() {
  info "First run — installing Claude Code..."
  npm install -g @anthropic-ai/claude-code --registry=https://registry.npmmirror.com 2>/dev/null \
    || npm install -g @anthropic-ai/claude-code
  ok "claude $(claude --version)"
  echo ""
}

link_file() {
  local src="$1" name
  name=$(basename "$src")
  local dst="$CLAUDE_HOME/$name"

  [[ -L "$dst" ]] && return
  if [[ -e "$dst" ]]; then
    info "Backing up $name -> $name.bak"
    mv "$dst" "$dst.bak"
  fi
  ln -s "$src" "$dst"
}

setup_links() {
  mkdir -p "$CLAUDE_HOME"

  for f in settings.json; do
    [[ -f "$SCRIPT_DIR/$f" ]] && link_file "$SCRIPT_DIR/$f"
  done
  for d in projects; do
    [[ -d "$SCRIPT_DIR/$d" ]] && link_file "$SCRIPT_DIR/$d"
  done
}

main() {
  load_env

  if ! is_installed; then
    do_install
  fi

  setup_links

  # Pass through ANTHROPIC_API_KEY from .env if set
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    exec env ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" claude "$@"
  else
    exec claude "$@"
  fi
}

main "$@"
