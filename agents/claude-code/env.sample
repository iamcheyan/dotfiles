# Claude Code 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# cp env.sample .env
#
# Claude Code 支持多种认证方式:
# 1. API Key (推荐用于脚本/CI)
# 2. OAuth 登录 (交互式: claude login)
#
# 如果已通过 OAuth 登录，无需配置 .env

# Anthropic API Key
# 获取: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=你的API_KEY

# 可选: 自定义 API Base URL (代理/企业部署)
# ANTHROPIC_BASE_URL=https://your-proxy.com/v1
