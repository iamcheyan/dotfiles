# OpenCode CLI (MiMo API) 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# cp env.sample .env

# API 提供商（openai 兼容协议）
provider=openai

# 模型名称
model=mimo-v2.5-pro

# MiMo API Key
# 按量付费: sk-xxxxx -> https://mimo.xiaomi.com/api-keys
# Token Plan: tp-xxxxx -> https://mimo.xiaomi.com/subscription/manage
MIMO_API_KEY=你的API_KEY

# MiMo API Base URL
# 按量付费:
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# Token Plan:
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
