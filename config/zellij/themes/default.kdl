themes {
default {
    fg "#a0f0a0"
    bg "#0a1a0a"
    black "#0a1a0a"
    red "#f7768e"
    green "#51fa7a"
    yellow "#e0af68"
    blue "#7aa2f7"
    magenta "#bb9af7"
    cyan "#7dcfff"
    white "#a0f0a0"
    orange "#ff9e64"

    // Pane border colors
    frame_unselected {
        base "#1a2e1a"
        emphasis_0 "#1a2e1a"
        emphasis_1 "#1a2e1a"
        emphasis_2 "#1a2e1a"
        emphasis_3 "#1a2e1a"
    }
    frame_selected {
        base "#2a4a2a"
        emphasis_0 "#2a4a2a"
        emphasis_1 "#2a4a2a"
        emphasis_2 "#2a4a2a"
        emphasis_3 "#2a4a2a"
    }
    frame_highlight {
        base "#51fa7a"
        emphasis_0 "#51fa7a"
        emphasis_1 "#51fa7a"
        emphasis_2 "#51fa7a"
        emphasis_3 "#51fa7a"
    }

    // Tab 颜色
    ribbon_selected {
        base "#0e1116"
        background "#f3f8f4"
        emphasis_0 "#0e1116"
        emphasis_1 "#0e1116"
        emphasis_2 "#0e1116"
        emphasis_3 "#0e1116"
    }
    ribbon_unselected {
        base "#0e1116"
        background "#51fa79"
        emphasis_0 "#0e1116"
        emphasis_1 "#0e1116"
        emphasis_2 "#0e1116"
        emphasis_3 "#0e1116"
    }

    // 会话名颜色
    text_unselected {
        base "#00fd7f"
        background "#000000"
        emphasis_0 "#00fd7f"
        emphasis_1 "#00fd7f"
        emphasis_2 "#00fd7f"
        emphasis_3 "#00fd7f"
    }
}
}
