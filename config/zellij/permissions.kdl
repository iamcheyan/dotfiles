// Zellij plugin permissions
// Pre-authorize plugins to avoid interactive prompts

permissions {
    zjstatus {
        ReadApplicationState
        ChangeApplicationState
    }
    zellij-attention {
        ReadApplicationState
    }
    zellij-pane-picker {
        ReadApplicationState
        ChangeApplicationState
    }
    notepad {
        ReadApplicationState
        ChangeApplicationState
    }
}
