layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zjstatus" {
                format_left   "{mode} {tabs}"
                format_center ""
                format_right  "#[bg=#50fa7b,fg=#0f1117,bold] {session} #[bg=#f8f8f2,fg=#282a36,bold] {datetime} "
                format_space  ""

                border_enabled  "false"
                border_char     "─"
                border_format   "#[fg=#50fa7b]{char}"
                border_position "top"

                hide_frame_for_single_pane "false"

                mode_locked      "#[bg=#0f1117,fg=#bfc7d5,bold]  LOCK "
                mode_normal      "#[bg=#0f1117,fg=#50fa7b,bold]  NORMAL "
                mode_resize      "#[bg=#0f1117,fg=#ffb86c,bold]  RESIZE "
                mode_pane        "#[bg=#0f1117,fg=#8be9fd,bold]  PANE "
                mode_move        "#[bg=#0f1117,fg=#69ff94,bold]  MOVE "
                mode_tab         "#[bg=#0f1117,fg=#f1fa8c,bold]  TAB "
                mode_scroll      "#[bg=#0f1117,fg=#7df9ff,bold]  SCROLL "
                mode_search      "#[bg=#0f1117,fg=#ff79c6,bold]  SEARCH "
                mode_entersearch "#[bg=#0f1117,fg=#ffd166,bold]  ENTER SEARCH "
                mode_renametab   "#[bg=#0f1117,fg=#f8f8f2,bold]  RENAME TAB "
                mode_renamepane  "#[bg=#0f1117,fg=#ff92df,bold]  RENAME PANE "
                mode_session     "#[bg=#0f1117,fg=#50fa7b,bold]  SESSION "
                mode_tmux        "#[bg=#0f1117,fg=#8be9fd,bold]  TMUX "

                tab_active              "#[bg=#f8f8f2,fg=#0f1117,bold] {name} "
                tab_active_fullscreen   "#[bg=#f8f8f2,fg=#0f1117,bold] {fullscreen_indicator} {name} "
                tab_active_sync         "#[bg=#f8f8f2,fg=#0f1117,bold] {sync_indicator} {name} "

                tab_normal              "#[bg=#50fa7b,fg=#0f1117,bold] {name} "
                tab_normal_fullscreen   "#[bg=#50fa7b,fg=#0f1117,bold] {fullscreen_indicator} {name} "
                tab_normal_sync         "#[bg=#50fa7b,fg=#0f1117,bold] {sync_indicator} {name} "

                tab_separator ""

                tab_sync_indicator       "󰓦"
                tab_fullscreen_indicator "󰊓"
                tab_floating_indicator   "⬚"

                tab_rename              "#[bg=#8be9fd,fg=#0f1117,bold] {index} {name} {floating_indicator} "

                tab_display_count         "9"
                tab_truncate_start_format "#[fg=#f8f8f2]  +{count}  "
                tab_truncate_end_format   "#[fg=#f8f8f2]   +{count} "

                datetime        "#[fg=#50fa7b,bold] {format} "
                datetime_format "%d %b %H:%M"
                datetime_timezone "Asia/Tokyo"
            }
        }
    }
    tab name="main"
}
