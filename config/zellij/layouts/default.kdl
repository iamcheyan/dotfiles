layout {
    pane size=1 borderless=true {
        plugin location="zj-status" {
            // -- 颜色定义 --
            color_rosewater "#f5e0dc"
            color_flamingo "#f2cdcd"
            color_pink "#f5c2e7"
            color_mauve "#cba6f7"
            color_red "#f38ba8"
            color_maroon "#eba0ac"
            color_peach "#fab387"
            color_yellow "#f9e2af"
            color_green "#a6e3a1"
            color_teal "#94e2d5"
            color_sky "#89dceb"
            color_sapphire "#74c7ec"
            color_blue "#89b4fa"
            color_lavender "#b4befe"
            color_text "#cdd6f4"
            color_subtext1 "#bac2de"
            color_subtext0 "#a6adc8"
            color_overlay2 "#9399b2"
            color_overlay1 "#7f849c"
            color_overlay0 "#6c7086"
            color_surface2 "#585b70"
            color_surface1 "#45475a"
            color_surface0 "#313244"
            color_base "#1e1e2e"
            color_mantle "#181825"
            color_crust "#11111b"

            // -- 布局定义 --
            format_left  "{mode} #[fg=$blue,bold]{session} {tabs}"
            format_right "{command_git_branch} {datetime}"
            format_space ""

            // -- 模式 (Mode) 样式 --
            mode_normal        "#[bg=$blue,fg=$crust,bold] NORMAL "
            mode_locked        "#[bg=$red,fg=$crust,bold] LOCKED "
            mode_pane          "#[bg=$teal,fg=$crust,bold] PANE "
            mode_tab           "#[bg=$mauve,fg=$crust,bold] TAB "
            mode_scroll        "#[bg=$yellow,fg=$crust,bold] SCROLL "
            mode_enter_search  "#[bg=$orange,fg=$crust,bold] ENTSCH "
            mode_search        "#[bg=$orange,fg=$crust,bold] SEARCH "
            mode_resize        "#[bg=$yellow,fg=$crust,bold] RESIZE "
            mode_rename_pane   "#[bg=$yellow,fg=$crust,bold] RNPANE "
            mode_rename_tab    "#[bg=$yellow,fg=$crust,bold] RNTAB "
            mode_session       "#[bg=$pink,fg=$crust,bold] SESSION "
            mode_move          "#[bg=$green,fg=$crust,bold] MOVE "
            mode_tmux          "#[bg=$maroon,fg=$crust,bold] TMUX "

            // -- 标签 (Tabs) 样式 --
            tab_normal   "#[fg=$overlay2,bg=$surface0] {index} {name} "
            tab_active   "#[fg=$blue,bg=$surface1,bold,italic] {index} {name} "

            // -- Git 分支样式 --
            command_git_branch_command     "git rev-parse --abbrev-ref HEAD"
            command_git_branch_format      "#[fg=$blue] {stdout} "
            command_git_branch_interval    "10"
            command_git_branch_rendermode  "static"

            datetime        "#[fg=$subtext1] {format} "
            datetime_format "%H:%M"
            datetime_timezone "Asia/Tokyo"
        }
    }
    pane
    pane size=1 borderless=true {
        plugin location="zj-status" {
            // 底部栏：保留你需要的按键提示
            format_left  "#[fg=$subtext0,italic] {mode}提示: #[fg=$text]Ctrl+p (Pane)  Ctrl+t (Tab)  Ctrl+n (Resize)  Alt+s (Search)  Ctrl+g (Lock)"
            format_right "#[fg=$maroon,bold] ZELLIJ "
            format_space ""
        }
    }
}
