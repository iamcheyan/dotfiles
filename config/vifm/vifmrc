" Vifm config

" 快速连接 alpine 练习容器（scp 浏览模式）
command! alpine :!
    \ echo "=== Alpine Practice ===" &&
    \ echo "sftp://student@localhost:2222" &&
    \ echo "密码: student" &&
    \ echo "" &&
    \ echo "建议: 用 termscp 或 lftp 连接远程，vifm 更适合本地文件管理"

" 常用设置
set vicmd=nvim
set syscalls
set trash
set history=100
set nofollowlinks
set number

colorscheme papercolor-dark
nnoremap yf :let @+ = expand('%:t')<cr>
nnoremap yp :let @+ = expand('%:p')<cr>
