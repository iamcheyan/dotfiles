#!/bin/bash

# 定义 dotfiles 目录的路径
DOTFILES_DIR="$HOME/dotfiles"

trim_text() {
    local text="$*"
    text="${text#"${text%%[![:space:]]*}"}"
    text="${text%"${text##*[![:space:]]}"}"
    printf '%s' "$text"
}

classify_scope() {
    local path="$1"

    case "$path" in
        config/zellij/*|plugins/zellij/*)
            echo "zellij"
            ;;
        config/nvim/*|plugins/nvim/*)
            echo "nvim"
            ;;
        aliases.conf|aliases/*)
            echo "shell aliases"
            ;;
        documents/*|doc/*|*.md|*.adoc|*.txt)
            echo "docs"
            ;;
        scripts/*)
            echo "scripts"
            ;;
        tools/*)
            echo "tools"
            ;;
        config/*)
            echo "$(echo "$path" | cut -d/ -f2)"
            ;;
        plugins/*)
            echo "$(echo "$path" | cut -d/ -f2)"
            ;;
        *)
            basename "$path" | sed 's/\.[^.]*$//'
            ;;
    esac
}

detect_commit_prefix() {
    local path

    if [ "$#" -eq 0 ]; then
        echo "chore"
        return
    fi

    for path in "$@"; do
        case "$path" in
            documents/*|doc/*|*.md|*.adoc|*.txt)
                ;;
            *)
                echo "chore"
                return
                ;;
        esac
    done

    echo "docs"
}

join_scopes() {
    local count="$#"

    if [ "$count" -eq 0 ]; then
        return
    fi

    if [ "$count" -eq 1 ]; then
        printf '%s' "$1"
        return
    fi

    if [ "$count" -eq 2 ]; then
        printf '%s and %s' "$1" "$2"
        return
    fi

    printf '%s, %s, and %s' "$1" "$2" "$3"
}

build_auto_commit_message() {
    local path scope prefix
    local -a staged_paths=()
    local -a unique_scopes=()

    while IFS= read -r path; do
        [ -n "$path" ] && staged_paths+=("$path")
    done < <(git diff --cached --name-only)

    if [ "${#staged_paths[@]}" -eq 0 ]; then
        echo "chore: sync dotfiles"
        return
    fi

    prefix=$(detect_commit_prefix "${staged_paths[@]}")

    for path in "${staged_paths[@]}"; do
        scope=$(classify_scope "$path")
        [ -z "$scope" ] && continue

        case " ${unique_scopes[*]} " in
            *" $scope "*)
                ;;
            *)
                unique_scopes+=("$scope")
                ;;
        esac

        [ "${#unique_scopes[@]}" -ge 3 ] && break
    done

    if [ "${#unique_scopes[@]}" -eq 0 ]; then
        echo "${prefix}: update dotfiles"
        return
    fi

    echo "${prefix}: update $(join_scopes "${unique_scopes[@]}")"
}

# 定义函数来处理备份操作
backup() {
    echo "正在备份配置..."

    # 导出Cinnamon配置
    if [ "$XDG_CURRENT_DESKTOP" = "X-Cinnamon" ]; then
        echo "检测到Cinnamon桌面环境，正在导出配置..."
        
        # 导出Cinnamon配置到当前目录
        dconf dump /org/cinnamon/ > "$DOTFILES_DIR/config/cinnamon_config.dconf"
        
        echo "Cinnamon配置已导出到：$DOTFILES_DIR/config/cinnamon_config.dconf"
    else
        echo "当前不是Cinnamon桌面环境，无法导出配置。"
    fi
    
    # 导出 GNOME 终端配置文件
    dconf dump /org/gnome/terminal/legacy/profiles:/ > $DOTFILES_DIR/config/gnome-terminal-profile.conf

    # 导出 GNOME 终端快捷键设置
    dconf dump /org/gnome/terminal/legacy/keybindings/ >> $DOTFILES_DIR/config/gnome-terminal-profile.conf

    # 导出 GNOME Shell 快捷键设置
    echo "正在导出 GNOME Shell 快捷键设置..."
    dconf dump /org/gnome/shell/keybindings/ > $DOTFILES_DIR/config/gnome-shell-keybindings.conf
    if [ $? -eq 0 ]; then
        echo "GNOME Shell 快捷键设置已成功导出到：$DOTFILES_DIR/config/gnome-shell-keybindings.conf"
    else
        echo "导出 GNOME Shell 快捷键设置时出错"
    fi

    # 备份 cursor 配置
    if [ -f "$DOTFILES_DIR/Scripts/cursor/config_backup.sh" ]; then
        bash $DOTFILES_DIR/Scripts/cursor/config_backup.sh
    fi

    echo "备份完成"
}

# 定义函数来处理恢复操作
restore() {
    sudo flatpak override org.gnome.Photos --env=GTK_THEME=Adwaita-dark  # 设置gnome-photos为暗色主题
    
    echo "正在恢复配置..."
    # 配置git（如果脚本存在）
    if [ -f "$DOTFILES_DIR/Scripts/install/resources/git_config.sh" ]; then
        bash $DOTFILES_DIR/Scripts/install/resources/git_config.sh
    fi

    # 恢复 cursor 配置
    if [ -f "$DOTFILES_DIR/Scripts/cursor/config_restore.sh" ]; then
        bash $DOTFILES_DIR/Scripts/cursor/config_restore.sh
    fi

    echo "正在恢复 GNOME 终端配置..."
    dconf load / < $DOTFILES_DIR/config/gnome-terminal-profile.conf
    if [ $? -eq 0 ]; then
        echo "GNOME 终端配置已成功恢复"
    else
        echo "恢复 GNOME 终端配置时出错"
    fi
    
    # 安装字体（使用统一的字体安装脚本）
    echo "正在安装字体..."
    if [ -f "$DOTFILES_DIR/scripts/install/install_font.sh" ]; then
        bash "$DOTFILES_DIR/scripts/install/install_font.sh" --noto --force
    else
        echo "警告: 未找到字体安装脚本: $DOTFILES_DIR/scripts/install/install_font.sh" >&2
    fi

    #bash $DOTFILES_DIR/Scripts/sync_data.sh restore         # 恢复数据
    
    ###########################################################################################
    echo "恢复完成"
}

pull() {
    cd $DOTFILES_DIR

    # 将 config/ssh 目录下的文件复制到 $HOME/.ssh/id_rsa（有就覆盖）
    if [ -f "$DOTFILES_DIR/config/ssh/id_rsa" ]; then
        mkdir -p "$HOME/.ssh"
        cp -f "$DOTFILES_DIR/config/ssh/id_rsa" "$HOME/.ssh/id_rsa"
        chmod 600 "$HOME/.ssh/id_rsa"
        echo "已将 config/ssh/id_rsa 复制到 $HOME/.ssh/id_rsa"
    fi
    
    # 重置到最新的提交
    git reset --hard
    # 获取所有远程更新
    git fetch --all
    # 重置到远程主分支
    git reset --hard origin/main

    # 成功后显示当前最新状态
    echo ""
    echo "当前 dotfiles 状态如下："
    git --no-pager log -1 --pretty=format:"%C(yellow)%h%Creset %Cgreen%ad%Creset %Cblue%an%Creset %s" --date=short
    echo ""
}

# 同步独立仓库功能已移除

push() {
    cd $DOTFILES_DIR
    echo "正在push配置：$DOTFILES_DIR"
    bash $DOTFILES_DIR/bin/dotlink backups    # 同步 dotfiles
    git add .

    # 检查暂存区文件大小，超过100MB的文件不提交
    maxsize=104857600  # 100MB
    files_to_unstage=()
    git diff --cached --name-only | while read filename; do
        if [ -f "$filename" ]; then
            size=$(wc -c <"$filename")
            if [ "$size" -gt "$maxsize" ]; then
                echo "🚫 忽略提交：$filename 文件超过 100MB（实际大小：$((size / 1024 / 1024)) MB）"
                files_to_unstage+=("$filename")
            fi
        fi
    done

    # 取消暂存超大文件
    for file in "${files_to_unstage[@]}"; do
        git reset HEAD -- "$file"
    done

    # 获取提交信息：优先使用手写 message，否则根据 staged 文件自动生成
    if [ $# -gt 0 ]; then
        commit_message=$(trim_text "$*")
    else
        commit_message=$(build_auto_commit_message)
    fi

    if [ -z "$commit_message" ]; then
        commit_message=$(build_auto_commit_message)
    fi

    git commit -m "$commit_message" --allow-empty

    # 尝试 push，如果遇到 remote 未配置的错误则自动添加 remote 并重试
    git push
    if [ $? -eq 0 ]; then
        echo "已执行 Git 推送"
    else
        # 检查是否是 remote 未配置的错误
        last_output=$(git push 2>&1)
        if echo "$last_output" | grep -q "fatal: No configured push destination"; then
            echo "未检测到远程仓库，正在添加 remote origin..."
            git remote add origin https://github.com/iamcheyan/dotfiles.git
            echo "已添加 remote origin，正在重新 push 并设置 upstream..."
            git push --set-upstream origin main
            if [ $? -eq 0 ]; then
                echo "已执行 Git 推送"
            else
                echo "Git 推送失败，请检查远程仓库配置"
            fi
        else
            echo "Git 推送失败，请检查错误信息"
            echo "$last_output"
        fi
    fi
}

log() {
    cd $DOTFILES_DIR
    git log --pretty=format:"%C(yellow)%h%Creset %Cgreen%ad%Creset %Cblue%an%Creset %s" --date=short
}

# 解析命令行参数
if [ $# -eq 0 ]; then
    echo "用法: $0 [backup] [restore] [pull] [push] [log]"
    echo "可以同时使用多个参数，例如: $0 backup pull"
    exit 1
else
    for arg in "$@"; do
        case "$arg" in
            backup)
                backup
                ;;
            restore)
                restore
                ;;
            pull)
                pull
                ;;
            push)
                shift
                push "$@"
                ;;
            log)
                log
                ;;
            *)
                echo "参数: $0 [backup] [restore] [pull] [push] [log]"
                exit 1
                ;;
        esac
    done
fi

# 如果没有提供参数，显示用法说明
if [ $# -eq 0 ]; then
    echo "用法: $0 [backup] [restore] [pull] [push] [log]"
    echo "可以同时使用多个参数，例如: $0 backup pull"
    exit 1
fi
