[link]
$HOME/dotfiles/zshrc:$HOME/.zshrc	# zsh 配置文件
$HOME/dotfiles/config/starship/starship.toml:$HOME/.config/starship.toml	# Starship 配置文件
$HOME/dotfiles/config/nano/nanorc:$HOME/.nanorc	# GNU nano 配置文件
$HOME/dotfiles/config/zellij:$HOME/.config/zellij	# Zellij 配置
$HOME/dotfiles/config/superfile:$HOME/.config/superfile                  #superfile
$HOME/dotfiles/config/atuin:$HOME/.config/atuin                          #atuin历史查询工具配置
$HOME/dotfiles/config/kitty/kitty.conf:$HOME/.config/kitty/kitty.conf      #kitty终端配置
$HOME/dotfiles/config/ghostty:$HOME/.config/ghostty                      #ghostty终端配置
$HOME/dotfiles/config/alacritty:$HOME/.config/alacritty                  #alacritty终端配置
$HOME/dotfiles/config/herdr/config.toml:$HOME/.config/herdr/config.toml				 #herdr

# ranger
$HOME/dotfiles/config/ranger:$HOME/.config/ranger

# vim
$HOME/dotfiles/config/vim/vimrc:$HOME/.vimrc	# Vim 配置文件
$HOME/dotfiles/config/gvim/gvimrc:$HOME/.gvimrc	# gvim 配置文件
$HOME/dotfiles/config/nvim:$HOME/.config/nvim	# Neovim 配置文件

# vifm
$HOME/dotfiles/config/vifm/vifmrc:$HOME/.config/vifm/vifmrc
$HOME/dotfiles/config/vifm/colors:$HOME/.config/vifm/colors
$HOME/dotfiles/config/vifm/scripts:$HOME/.config/vifm/scripts

# tmux
$HOME/dotfiles/config/tmux/tmux.conf:$HOME/.tmux.conf

# fcitx5
$HOME/dotfiles/config/fcitx5/config:$HOME/.config/fcitx5/config
$HOME/dotfiles/config/fcitx5/conf/classicui.conf:$HOME/.config/fcitx5/conf/classicui.conf
$HOME/dotfiles/config/fcitx5/profile:$HOME/.config/fcitx5/profile

