#!/usr/bin/env bash
set -euo pipefail

# Cline CLI (MiMo) — install if missing, then launch with MiMo API
# 首次运行自动安装，通过环境变量注入 MiMo API（不修改用户 auth 配置）

CLINE_NODE_VERSION="22"
CLINE_NVM_ALIAS="cline"
CLINE_PKG="cline"

info()  { printf "\033[1;34m[INFO]\033[0m  %s\n" "$*"; }
ok()    { printf "\033[1;32m[OK]\033[0m    %s\n" "$*"; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$ENV_FILE"
    set +a
  fi
}

ensure_nvm() {
  if command -v nvm &>/dev/null; then
    return
  fi
  local nvm_dir="${NVM_DIR:-$HOME/.nvm}"
  if [[ -s "$nvm_dir/nvm.sh" ]]; then
    # shellcheck source=/dev/null
    source "$nvm_dir/nvm.sh"
    return
  fi
  info "Installing nvm..."
  curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
  export NVM_DIR="$nvm_dir"
  # shellcheck source=/dev/null
  [[ -s "$nvm_dir/nvm.sh" ]] && source "$nvm_dir/nvm.sh"
}

is_installed() {
  nvm exec "$CLINE_NVM_ALIAS" command -v cline &>/dev/null 2>&1
}

do_install() {
  info "First run — installing Cline CLI..."

  nvm install "$CLINE_NODE_VERSION"
  nvm alias "$CLINE_NVM_ALIAS" "$CLINE_NODE_VERSION" 2>/dev/null || true
  ok "Node.js $(nvm exec "$CLINE_NVM_ALIAS" node --version)"

  nvm exec "$CLINE_NVM_ALIAS" npm install -g "$CLINE_PKG"
  ok "cline $(nvm exec "$CLINE_NVM_ALIAS" cline --version 2>/dev/null || echo 'installed')"
  echo ""
}

main() {
  load_env
  ensure_nvm

  if ! is_installed; then
    do_install
  fi

  # Launch with MiMo API key from .env injected as env var
  # Does NOT modify user's cline auth — direct `cline` still uses user's own provider
  nvm exec "$CLINE_NVM_ALIAS" \
    env OPENAI_API_KEY="${MIMO_API_KEY:-}" \
       OPENAI_BASE_URL="${MIMO_BASE_URL:-https://token-plan-cn.xiaomimimo.com/v1}" \
    cline "$@"
}

main "$@"
